rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ÚJ SZABÁLY: Eszköz vizsgálati mellékletek (pl. PDF feltöltés, UEVM képek ha lennének)
    match /partners/{partnerId}/devices/{deviceId}/inspections/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Fallback for potential casing issues
    match /partners/{partnerId}/devices/{deviceId}/Inspections/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Használatba vételi dokumentumok
    match /partners/{partnerId}/usage_docs/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Generált vizsgálati jegyzőkönyvek (HTML)
    match /generated-inspections/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
