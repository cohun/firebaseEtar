rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ÚJ SZABÁLY: Eszköz vizsgálati mellékletek (pl. PDF feltöltés, UEVM képek ha lennének)
    match /partners/{partnerId}/devices/{deviceId}/inspections/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Fallback for potential casing issues
    match /partners/{partnerId}/devices/{deviceId}/Inspections/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // ÚJ SZABÁLY: Eszközökhöz csatolt dokumentumok feltöltése és limitációi
    // Maximum 10MB (10 * 1024 * 1024 bytes) és csak PDF, JPG, PNG engedélyezett.
    match /partners/{partnerId}/devices/{deviceId}/attached_documents/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && request.resource.size <= 10 * 1024 * 1024 // 10 MB limit
                   && request.resource.contentType.matches('application/pdf|image/jpeg|image/png');
      allow delete: if request.auth != null;
    }

    // Használatba vételi dokumentumok
    match /partners/{partnerId}/usage_docs/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Generált vizsgálati jegyzőkönyvek (HTML)
    match /generated-inspections/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Szakértői Tudástár Fájlok (PDF szabványok, leírások)
    match /expert_knowledge_files/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
